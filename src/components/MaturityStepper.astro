---
interface Props {
  basePath: string;
  courseSlug: string;
  variant?: 'default' | 'home';
}

const { basePath, courseSlug, variant = 'default' } = Astro.props;

const levels = [
  {
    number: 1,
    title: 'Chat',
    subtitle: 'Q&A basique',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    number: 2,
    title: 'Copilote',
    subtitle: 'Assistance contextualisée',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    number: 3,
    title: 'Agent guidé',
    subtitle: 'Exécution supervisée',
    objective: 'Objectif à court terme',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2',
  },
  {
    number: 4,
    title: 'Human in the Loop',
    subtitle: 'Workflow automatisé contrôlé',
    objective: 'Objectif à moyen terme',
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581',
  },
  {
    number: 5,
    title: 'Swarm',
    subtitle: 'Orchestration multi-agents',
    objective: 'Objectif à long terme',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
];

const isHome = variant === 'home';
const actionHref = isHome
  ? `${basePath}quiz-niveau`
  : `${basePath}lessons/${courseSlug}/niveaux-maturite`;
const actionLabel = isHome ? 'Me situer avec le quiz' : 'Voir le détail';
---

<div class:list={['surface-card maturity-shell', isHome ? 'p-6 md:p-7' : 'p-5 md:p-6']}>
  <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs font-semibold tracking-[0.14em] text-[var(--text-faint)] uppercase">Repère d'équipe</p>
      <h2 class="section-title mt-1 text-2xl md:text-3xl">Niveaux de maturité IA</h2>
      <p class="mt-2 max-w-3xl text-sm text-[var(--text-muted)]">
        Le quiz nous situe rapidement. Cette grille nous aide ensuite à choisir la prochaine étape de progression.
      </p>
    </div>

    <a
      href={actionHref}
      class="btn-ghost !px-4 !py-2 !text-xs md:!text-sm"
    >
      {actionLabel}
    </a>
  </div>

  <div class="relative overflow-x-auto rounded-2xl border border-[var(--border)] bg-[color-mix(in_srgb,var(--surface-strong)_78%,transparent)] px-4 py-6 md:px-6">
    <div class="maturity-track absolute top-[57px] right-8 left-8 hidden h-1 rounded-full bg-[var(--border)] md:block"></div>
    <div class="maturity-track-fill absolute top-[57px] left-8 hidden h-1 rounded-full md:block"></div>

    <div class="relative grid min-w-[860px] gap-3 md:grid-cols-5 md:gap-4">
      {
        levels.map((level, index) => (
          <article class="maturity-card h-full rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-4 text-center" style={`--delay:${index * 90}ms`}>
            <div class="flex h-full flex-col items-center">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] text-[var(--text-primary)] shadow-sm">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={level.icon}></path>
                </svg>
              </div>

              <p class="mt-3 text-[11px] font-semibold tracking-[0.14em] text-[var(--text-faint)] uppercase">Niveau {level.number}</p>
              <p class="mt-1 text-base font-bold text-[var(--text-primary)]">{level.title}</p>
              <p class="mt-0.5 text-sm text-[var(--text-muted)]">{level.subtitle}</p>

              <div class="mt-auto pt-3">
                {
                  level.objective ? (
                    <p class="inline-flex min-h-[30px] items-center rounded-full border border-[var(--brand-300)] bg-[rgba(23,229,23,0.12)] px-2.5 py-1 text-[11px] font-semibold text-[var(--brand-700)]">
                      {level.objective}
                    </p>
                  ) : (
                    <span class="inline-flex min-h-[30px] items-center px-2.5 py-1 text-[11px] opacity-0">objectif</span>
                  )
                }
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  {
    isHome && (
      <p class="mt-4 rounded-xl border border-[var(--brand-300)] bg-[rgba(23,229,23,0.09)] px-4 py-3 text-sm leading-relaxed font-semibold text-[var(--text-primary)]">
        Notre cap collectif: atteindre le niveau 3 à court terme, stabiliser le niveau 4 à moyen terme, puis industrialiser le niveau 5 à long terme.
      </p>
    )
  }
</div>