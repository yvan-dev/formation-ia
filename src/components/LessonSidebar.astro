---
interface Props {
  courseSlug: string;
  courseTitle: string;
  modules: Array<{
    title: string;
    lessons: Array<{
      slug: string;
      title: string;
    }>;
  }>;
  currentLesson: string;
}

const { courseSlug, courseTitle, modules, currentLesson } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="px-4 py-5">
  <a
    href={`${base}courses/${courseSlug}`}
    class="mb-5 inline-flex items-center gap-2 text-sm font-semibold text-[var(--text-muted)] transition-colors hover:text-[var(--text-primary)]"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 19l-7-7 7-7"
      />
    </svg>
    <span class="truncate">{courseTitle}</span>
  </a>

  {
    modules.map((module, moduleIndex) => (
      <div class="mb-5">
        <h4 class="mb-2 px-2 text-xs font-semibold tracking-[0.1em] text-[var(--text-faint)] uppercase">
          Module {moduleIndex + 1} · {module.title}
        </h4>

        <ul class="space-y-1">
          {module.lessons.map((lesson) => {
            const isActive = lesson.slug === currentLesson;
            return (
              <li>
                <a
                  href={`${base}lessons/${courseSlug}/${lesson.slug}`}
                  data-lesson-link={lesson.slug}
                  class:list={[
                    'group flex items-center gap-2 rounded-lg border px-2.5 py-2 text-sm transition-colors',
                    isActive
                      ? 'border-[var(--brand-400)] bg-[rgba(23,229,23,0.11)] text-[var(--text-primary)]'
                      : 'border-transparent text-[var(--text-muted)] hover:border-[var(--border)] hover:bg-[var(--surface-strong)] hover:text-[var(--text-primary)]',
                  ]}
                >
                  <span class="lesson-check hidden text-[var(--brand-400)]">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </span>
                  <span class="lesson-dot inline-block h-1.5 w-1.5 rounded-full bg-[var(--text-faint)]"></span>
                  <span class="flex-1 truncate">{lesson.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</div>

<script is:inline>
  (function () {
    const firstLink = document.querySelector('[data-lesson-link]');
    if (!firstLink) return;

    const href = firstLink.getAttribute('href') || '';
    const parts = href.split('/').filter(Boolean);
    const lessonsIdx = parts.indexOf('lessons');
    if (lessonsIdx === -1) return;

    const courseSlug = parts[lessonsIdx + 1];
    if (!courseSlug) return;

    const progress = JSON.parse(localStorage.getItem(`progress_${courseSlug}`) || '[]');

    progress.forEach((slug) => {
      const links = document.querySelectorAll(`[data-lesson-link="${slug}"]`);
      links.forEach((link) => {
        const check = link.querySelector('.lesson-check');
        const dot = link.querySelector('.lesson-dot');
        if (check) check.classList.remove('hidden');
        if (dot) dot.classList.add('hidden');
      });
    });
  })();
</script>

