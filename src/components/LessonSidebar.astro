---
interface Props {
  courseSlug: string;
  courseTitle: string;
  modules: Array<{
    title: string;
    lessons: Array<{
      slug: string;
      title: string;
    }>;
  }>;
  currentLesson: string;
}

const { courseSlug, courseTitle, modules, currentLesson } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="px-4 py-6">
  <a
    href={`${base}courses/${courseSlug}`}
    class="text-navy-400 hover:text-acton-500 mb-6 flex items-center gap-2 text-sm transition-colors duration-200"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 19l-7-7 7-7"></path>
    </svg>
    <span class="truncate">{courseTitle}</span>
  </a>

  {
    modules.map((module, moduleIndex) => (
      <div class="mb-6">
        <h4 class="text-navy-500 mb-3 px-3 text-xs font-semibold tracking-wider uppercase">
          Module {moduleIndex + 1} — {module.title}
        </h4>
        <ul class="space-y-0.5">
          {module.lessons.map((lesson) => {
            const isActive = lesson.slug === currentLesson;
            return (
              <li>
                <a
                  href={`${base}lessons/${courseSlug}/${lesson.slug}`}
                  data-lesson-link={lesson.slug}
                  class:list={[
                    'flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-all duration-200',
                    isActive
                      ? 'bg-acton-600/10 text-acton-500 border-acton-600/20 border'
                      : 'text-navy-400 hover:text-navy-200 hover:bg-navy-800/50',
                  ]}
                >
                  <span class="lesson-check hidden shrink-0 text-green-400">
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </span>
                  <span
                    class:list={[
                      'lesson-dot h-1.5 w-1.5 shrink-0 rounded-full transition-colors',
                      isActive ? 'bg-acton-500' : 'bg-navy-600',
                    ]}
                  />
                  <span class="flex-1 truncate">{lesson.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</div>

<script is:inline>
  // Restore completed state from localStorage
  (function () {
    const sidebar = document
      .querySelector('[data-lesson-link]')
      ?.closest('[class*="py-6"]');
    if (!sidebar) return;
    const firstLink = sidebar.querySelector('[data-lesson-link]');
    if (!firstLink) return;

    const href = firstLink.getAttribute('href') || '';
    const parts = href.split('/').filter(Boolean);
    const lessonsIdx = parts.indexOf('lessons');
    if (lessonsIdx === -1) return;
    const courseSlug = parts[lessonsIdx + 1];
    if (!courseSlug) return;

    const progress = JSON.parse(
      localStorage.getItem(`progress_${courseSlug}`) || '[]',
    );
    progress.forEach(function (slug) {
      const links = document.querySelectorAll(`[data-lesson-link="${slug}"]`);
      links.forEach(function (link) {
        const check = link.querySelector('.lesson-check');
        const dot = link.querySelector('.lesson-dot');
        if (check) check.classList.remove('hidden');
        if (dot) dot.classList.add('hidden');
      });
    });
  })();
</script>
