---
interface Props {
  slug: string;
  title: string;
  description: string;
  level: string;
  lessonCount: number;
}

const { slug, title, description, level, lessonCount } = Astro.props;
const base = import.meta.env.BASE_URL;

const levelConfig: Record<
  string,
  { color: string; bg: string; border: string; icon: string }
> = {
  Débutant: {
    color: 'text-sage-400',
    bg: 'bg-sage-500/8',
    border: 'border-sage-500/15',
    icon: '01',
  },
  Intermédiaire: {
    color: 'text-amber-400',
    bg: 'bg-amber-500/8',
    border: 'border-amber-500/15',
    icon: '02',
  },
  Avancé: {
    color: 'text-coral-400',
    bg: 'bg-coral-500/8',
    border: 'border-coral-500/15',
    icon: '03',
  },
};

const cfg = levelConfig[level] || levelConfig.Débutant;
---

<a
  href={`${base}courses/${slug}`}
  class="group border-ink-700/30 bg-ink-900/40 hover:bg-ink-900/70 hover:border-gold-500/20 block rounded-2xl border transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/20"
>
  <!-- Course visual header -->
  <div class="relative aspect-[16/10] overflow-hidden rounded-t-2xl">
    <div
      class="from-ink-800 via-ink-800/90 to-ink-900 absolute inset-0 bg-gradient-to-br"
    >
    </div>
    <div
      class="from-gold-500/[0.06] absolute inset-0 bg-gradient-to-br to-transparent"
    >
    </div>
    <!-- Decorative grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(var(--color-ink-400) 1px, transparent 1px), linear-gradient(90deg, var(--color-ink-400) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="relative">
        <span
          class="font-display text-ink-600/40 group-hover:text-gold-500/20 text-6xl font-bold transition-colors duration-500"
          >{cfg.icon}</span
        >
      </div>
    </div>
    <!-- Level badge overlaid -->
    <div class="absolute top-4 left-4">
      <span
        class={`text-xs font-semibold px-2.5 py-1 rounded-lg border ${cfg.bg} ${cfg.color} ${cfg.border}`}
      >
        {level}
      </span>
    </div>
  </div>

  <div class="p-6">
    <h3
      class="font-display text-ink-50 group-hover:text-gold-400 mb-2.5 text-xl leading-snug font-semibold transition-colors duration-300"
    >
      {title}
    </h3>

    <p class="text-ink-400 mb-5 line-clamp-2 text-sm leading-relaxed">
      {description}
    </p>

    <div
      class="border-ink-800/50 flex items-center justify-between border-t pt-4"
    >
      <div class="text-ink-500 flex items-center gap-1.5 text-sm">
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
          ></path>
        </svg>
        <span>{lessonCount} leçons</span>
      </div>
    </div>
  </div>
</a>
