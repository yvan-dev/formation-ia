---
interface Props {
  slug: string;
  title: string;
  description: string;
  level?: string;
  lessonCount: number;
  moduleCount?: number;
  ctaLabel?: string;
}

const { slug, title, description, level, lessonCount, moduleCount, ctaLabel = 'Programme détaillé' } = Astro.props;
const base = import.meta.env.BASE_URL;

const levelMap: Record<string, string> = {
  Débutant: 'bg-[rgba(52,168,54,0.16)] text-[var(--brand-700)]',
  Intermédiaire: 'bg-[rgba(23,229,23,0.16)] text-[var(--brand-900)]',
  Avancé: 'bg-[rgba(0,0,0,0.82)] text-[var(--brand-500)]',
};
---

<a
  href={`${base}courses/${slug}`}
  class="group surface-card reveal block overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[var(--shadow-strong)]"
>
  <div class="relative overflow-hidden border-b border-[var(--border)] bg-[color-mix(in_srgb,var(--surface-strong)_78%,transparent)] px-5 py-5">
    <div class="grid-pattern"></div>
    <div class="relative flex items-start justify-between gap-4">
      <div>
        {
          level && (
            <span class:list={['course-badge', levelMap[level] || 'bg-[var(--surface-strong)] text-[var(--text-muted)]']}>
              {level}
            </span>
          )
        }
      </div>
      {
        typeof moduleCount === 'number' ? (
          <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-xs font-mono font-semibold text-[var(--text-faint)]">
            {String(moduleCount).padStart(2, '0')} modules actifs
          </div>
        ) : (
          <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-2 py-1 text-xs font-mono font-semibold text-[var(--text-faint)]">
            {String(lessonCount).padStart(2, '0')} leçons
          </div>
        )
      }
    </div>

    <h3 class="section-title relative mt-4 text-xl text-[var(--text-primary)]">{title}</h3>
  </div>

  <div class="p-5">
    <p class="line-clamp-3 text-sm leading-relaxed text-[var(--text-muted)]">{description}</p>

    <div class="mt-5 flex items-center justify-between border-t border-[var(--border)] pt-4">
      <span class="text-xs font-semibold tracking-[0.14em] text-[var(--text-faint)] uppercase">
        {ctaLabel}
      </span>
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[var(--border)] bg-[var(--surface-strong)] text-[var(--text-muted)] transition-all duration-300 group-hover:border-[var(--brand-400)] group-hover:text-[var(--brand-400)]">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </span>
    </div>
  </div>
</a>