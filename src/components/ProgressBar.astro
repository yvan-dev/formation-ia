---
interface Props {
  courseSlug: string;
  totalLessons: number;
}

const { courseSlug, totalLessons } = Astro.props;
---

<div
  class="h-1.5 overflow-hidden border-b border-[var(--border)] bg-[var(--surface-strong)]"
  id="progress-bar-container"
  data-course={courseSlug}
  data-total={totalLessons}
>
  <div id="progress-bar-fill" class="h-full transition-all duration-500 ease-out" style="width:0%;background:var(--gradient-brand)"></div>
</div>

<script is:inline>
  (function () {
    const container = document.getElementById('progress-bar-container');
    const fill = document.getElementById('progress-bar-fill');
    if (!container || !fill) return;

    const course = container.dataset.course;
    const total = parseInt(container.dataset.total || '0');

    function updateBar() {
      const progress = JSON.parse(localStorage.getItem(`progress_${course}`) || '[]');
      const pct = total > 0 ? Math.round((progress.length / total) * 100) : 0;
      fill.style.width = pct + '%';
    }

    updateBar();
    window.addEventListener('lesson-completed', updateBar);
  })();
</script>
