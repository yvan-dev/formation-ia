---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { slug: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const {
  title,
  description,
  modules,
  publicCible,
  prerequis,
  format,
  livrableFinal,
  objectifsGlobaux,
} = course.data;

const base = import.meta.env.BASE_URL;

interface Lesson {
  slug: string;
  title: string;
}

interface Module {
  title: string;
  public?: 'tous' | 'profils techniques';
  objectifs?: string[];
  livrable?: string;
  exercices?: string[];
  released?: boolean;
  lessons: Lesson[];
}

const availableModules = modules.filter((module: Module, index: number) =>
  typeof module.released === 'boolean' ? module.released : index < 3,
);
const comingSoonModules = modules.filter((module: Module, index: number) =>
  typeof module.released === 'boolean' ? !module.released : index >= 3,
);

const totalLessons = availableModules.reduce(
  (a: number, m: Module) => a + m.lessons.length,
  0,
);

const availableLessonSlugs = availableModules.flatMap((module: Module) =>
  module.lessons.map((lesson: Lesson) => lesson.slug),
);

const hasMetadata = publicCible || prerequis || format || livrableFinal;
---

<BaseLayout title={title}>
  <section class="container-shell py-8 md:py-10">
    <div class="surface-card overflow-hidden px-6 py-8 md:px-8 md:py-10">
      <nav class="mb-4 flex items-center gap-2 text-xs font-semibold tracking-[0.08em] text-[var(--text-faint)] uppercase" aria-label="Fil d'Ariane">
        <a href={base} class="transition-colors hover:text-[var(--text-primary)]">Accueil</a>
        <span>/</span>
        <span class="text-[var(--text-muted)]">Formation</span>
      </nav>

      <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <h1 class="section-title text-3xl text-[var(--text-primary)] md:text-5xl">{title}</h1>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-[var(--text-muted)] md:text-lg">{description}</p>
        </div>

        <div class="rounded-2xl border border-[var(--border)] bg-[var(--surface-strong)] p-4">
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 py-3 text-center">
              <p class="text-xs text-[var(--text-faint)]">Modules actifs</p>
              <p class="section-title mt-1 text-2xl">{availableModules.length}</p>
            </div>
            <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 py-3 text-center">
              <p class="text-xs text-[var(--text-faint)]">Leçons disponibles</p>
              <p class="section-title mt-1 text-2xl">{totalLessons}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell grid gap-6 pb-4 md:grid-cols-[1.15fr_0.85fr]">
    <div class="surface-card p-6 md:p-7">
      <p class="text-xs font-semibold tracking-[0.14em] text-[var(--text-faint)] uppercase">Étape recommandée</p>
      <h2 class="section-title mt-2 text-2xl">Commencer par le quiz de placement</h2>
      <p class="mt-2 text-sm text-[var(--text-muted)]">
        Nous avons retiré le quiz de cette page pour garder un seul objectif: se positionner d'abord, puis suivre les modules adaptés.
      </p>
      <div class="mt-4">
        <a href={`${base}quiz-niveau`} class="btn-primary">Faire un quiz de placement</a>
      </div>
    </div>

    <div class="space-y-6">
      {
        hasMetadata && (
          <div class="surface-card p-6">
            <h2 class="section-title text-xl">Informations sur la formation</h2>
            <div class="mt-4 space-y-4 text-sm text-[var(--text-muted)]">
              {publicCible && (
                <div>
                  <p class="text-xs font-semibold tracking-[0.12em] text-[var(--text-faint)] uppercase">Public cible</p>
                  <p class="mt-1">{publicCible}</p>
                </div>
              )}
              {prerequis && (
                <div>
                  <p class="text-xs font-semibold tracking-[0.12em] text-[var(--text-faint)] uppercase">Prérequis</p>
                  <p class="mt-1">{prerequis}</p>
                </div>
              )}
              {format && (
                <div>
                  <p class="text-xs font-semibold tracking-[0.12em] text-[var(--text-faint)] uppercase">Format</p>
                  <p class="mt-1">{format}</p>
                </div>
              )}
              {livrableFinal && (
                <div>
                  <p class="text-xs font-semibold tracking-[0.12em] text-[var(--text-faint)] uppercase">Livrable final</p>
                  <p class="mt-1">{livrableFinal}</p>
                </div>
              )}
            </div>
          </div>
        )
      }
    </div>
  </section>

  {
    objectifsGlobaux && objectifsGlobaux.length > 0 && (
      <section class="container-shell py-8">
        <div class="surface-card p-6 md:p-7">
          <h2 class="section-title text-2xl">Objectifs du parcours</h2>
          <ul class="mt-4 grid gap-3 md:grid-cols-2">
            {objectifsGlobaux.map((obj: string) => (
              <li class="rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3 text-sm text-[var(--text-muted)]">
                {obj}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section class="container-shell py-6">
    <div class="surface-card p-5 md:p-6">
      <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="section-title text-2xl">Progression de la formation</h2>
        <span class="text-sm text-[var(--text-faint)]" id="progress-text">0 / {totalLessons} leçons</span>
      </div>
      <div class="h-2 overflow-hidden rounded-full bg-[var(--surface-strong)]">
        <div id="course-progress-fill" class="h-full rounded-full" style="width:0%;background:var(--gradient-brand)"></div>
      </div>
    </div>
  </section>

  <section class="container-shell space-y-6 py-8">
    {
      availableModules.map((module: Module, moduleIndex: number) => (
        <article class="surface-card overflow-hidden">
          <div class="border-b border-[var(--border)] bg-[var(--surface-strong)] px-5 py-4 md:px-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h2 class="section-title text-xl">
                <span class="mr-2 text-[var(--brand-400)]">Module {moduleIndex + 1}</span>
                {module.title}
              </h2>

              {module.public && (
                <span
                  class:list={[
                    'course-badge',
                    module.public === 'tous'
                      ? 'bg-[rgba(23,229,23,0.15)] text-[var(--brand-700)]'
                      : 'bg-[rgba(14,48,15,0.15)] text-[var(--text-primary)]',
                  ]}
                >
                  {module.public === 'tous' ? 'Tous profils' : 'Profils techniques'}
                </span>
              )}
            </div>

            {module.objectifs && module.objectifs.length > 0 && (
              <ul class="mt-3 space-y-1.5 text-sm text-[var(--text-muted)]">
                {module.objectifs.slice(0, 3).map((obj: string) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-[var(--brand-400)]"></span>
                    <span>{obj}</span>
                  </li>
                ))}
              </ul>
            )}

            {module.livrable && (
              <p class="mt-3 text-sm text-[var(--text-muted)]">
                <span class="font-semibold text-[var(--text-primary)]">Livrable:</span> {module.livrable}
              </p>
            )}
          </div>

          <ul>
            {module.lessons.map((lesson: Lesson, lessonIndex: number) => (
              <li class="border-b border-[var(--border)] last:border-none">
                <a
                  href={`${base}lessons/${course.id}/${lesson.slug}`}
                  data-lesson-item={lesson.slug}
                  class="group flex items-center gap-4 px-5 py-4 transition-colors hover:bg-[var(--surface-strong)] md:px-6"
                >
                  <div class="lesson-number flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-[var(--border)] bg-[var(--surface)] text-sm font-semibold text-[var(--text-faint)] transition-colors group-hover:border-[var(--brand-400)] group-hover:text-[var(--brand-400)]">
                    {lessonIndex + 1}
                  </div>
                  <span class="flex-1 text-sm font-medium text-[var(--text-muted)] transition-colors group-hover:text-[var(--text-primary)]">{lesson.title}</span>
                  <svg class="h-4 w-4 text-[var(--text-faint)] transition-colors group-hover:text-[var(--brand-400)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))
    }

    {
      comingSoonModules.length > 0 && (
        <div class="surface-card p-6 md:p-7">
          <h2 class="section-title text-xl">Modules à venir</h2>
          <p class="mt-2 text-sm text-[var(--text-muted)]">
            Ces modules seront activés progressivement après stabilisation du socle opérationnel.
          </p>
          <ul class="mt-4 grid gap-3 md:grid-cols-2">
            {comingSoonModules.map((module: Module) => (
              <li class="rounded-xl border border-dashed border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3 text-sm text-[var(--text-muted)]">
                <span class="inline-flex items-center gap-2 font-semibold text-[var(--text-primary)]">
                  <span class="inline-flex h-2 w-2 rounded-full bg-[var(--text-faint)]"></span>
                  {module.title}
                </span>
                <p class="mt-1 text-xs text-[var(--text-faint)]">Bientôt disponible</p>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>

  <script is:inline define:vars={{ courseId: course.id, totalLessons, availableLessonSlugs }}>
    (function () {
      const allowed = new Set(availableLessonSlugs || []);
      const progress = JSON.parse(localStorage.getItem(`progress_${courseId}`) || '[]').filter((slug) =>
        allowed.has(slug),
      );
      const pct = totalLessons > 0 ? Math.round((progress.length / totalLessons) * 100) : 0;

      const fill = document.getElementById('course-progress-fill');
      const text = document.getElementById('progress-text');

      if (fill) fill.style.width = pct + '%';
      if (text) text.textContent = progress.length + ' / ' + totalLessons + ' leçons';

      progress.forEach((slug) => {
        const item = document.querySelector(`[data-lesson-item="${slug}"]`);
        if (!item) return;

        const numEl = item.querySelector('.lesson-number');
        if (!numEl) return;

        numEl.innerHTML =
          '<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
        numEl.style.borderColor = 'var(--brand-400)';
        numEl.style.color = 'var(--brand-400)';
        numEl.style.background = 'var(--surface)';
      });
    })();
  </script>
</BaseLayout>