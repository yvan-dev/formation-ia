---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LevelQuiz from '../../components/LevelQuiz.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({
    params: { slug: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const {
  title,
  description,
  modules,
  publicCible,
  prerequis,
  format,
  livrableFinal,
  objectifsGlobaux,
} = course.data;
const base = import.meta.env.BASE_URL;

interface Lesson {
  slug: string;
  title: string;
}

interface Module {
  title: string;
  public?: 'tous' | 'profils techniques';
  objectifs?: string[];
  livrable?: string;
  exercices?: string[];
  lessons: Lesson[];
}

const totalLessons = modules.reduce(
  (a: number, m: Module) => a + m.lessons.length,
  0,
);

const hasMetadata = publicCible || prerequis || format || livrableFinal;
---

<BaseLayout title={title}>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <!-- Course header -->
    <div class="mb-12">
      <nav
        class="mb-6 flex items-center gap-2 text-sm text-slate-500"
        aria-label="Breadcrumb"
      >
        <a href={base} class="transition-colors hover:text-slate-300">Accueil</a
        >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path></svg
        >
        <span class="text-slate-300">{title}</span>
      </nav>

      <h1 class="mb-4 text-3xl font-bold text-slate-100 lg:text-4xl">
        {title}
      </h1>
      <p class="mb-6 text-lg leading-relaxed text-slate-400">{description}</p>

      <div class="flex flex-wrap items-center gap-4">
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
            ></path></svg
          >
          {totalLessons} leçons
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
            ></path></svg
          >
          {modules.length} modules
        </div>
      </div>
    </div>

    <!-- Quiz de niveau -->
    <div class="mb-8">
      <div class="mb-4 flex items-center gap-2">
        <svg class="h-5 w-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <h2 class="text-base font-semibold text-slate-200">Evaluez votre niveau</h2>
      </div>
      <p class="mb-4 text-sm text-slate-400">Repondez a 10 questions pour estimer vos connaissances en IA et savoir par ou commencer.</p>
      <LevelQuiz client:load basePath={base} />
    </div>

    <!-- Objectifs globaux -->
    {
      objectifsGlobaux && objectifsGlobaux.length > 0 && (
        <div class="mb-8 rounded-xl border border-slate-800 bg-slate-900/50 p-6">
          <h2 class="mb-4 flex items-center gap-2 text-base font-semibold text-slate-200">
            <svg
              class="h-5 w-5 text-violet-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
              />
            </svg>
            Objectifs globaux
          </h2>
          <ul class="space-y-2">
            {objectifsGlobaux.map((obj: string) => (
              <li class="flex items-start gap-2 text-sm text-slate-400">
                <svg
                  class="mt-0.5 h-4 w-4 shrink-0 text-violet-400/60"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                {obj}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- Metadata card -->
    {
      hasMetadata && (
        <div class="mb-8 grid gap-4 sm:grid-cols-2">
          {publicCible && (
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
              <div class="mb-1 text-xs font-medium tracking-wider text-slate-500 uppercase">
                Public cible
              </div>
              <div class="text-sm text-slate-300">{publicCible}</div>
            </div>
          )}
          {prerequis && (
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
              <div class="mb-1 text-xs font-medium tracking-wider text-slate-500 uppercase">
                Prérequis
              </div>
              <div class="text-sm text-slate-300">{prerequis}</div>
            </div>
          )}
          {format && (
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
              <div class="mb-1 text-xs font-medium tracking-wider text-slate-500 uppercase">
                Format
              </div>
              <div class="text-sm text-slate-300">{format}</div>
            </div>
          )}
          {livrableFinal && (
            <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-4">
              <div class="mb-1 text-xs font-medium tracking-wider text-slate-500 uppercase">
                Livrable final
              </div>
              <div class="text-sm text-slate-300">{livrableFinal}</div>
            </div>
          )}
        </div>
      )
    }

    <!-- Course progress -->
    <div class="mb-10 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
      <div class="mb-3 flex items-center justify-between">
        <span class="text-sm font-medium text-slate-300">Votre progression</span
        >
        <span class="text-sm text-slate-500" id="progress-text"
          >0 / {totalLessons} leçons</span
        >
      </div>
      <div class="h-2 overflow-hidden rounded-full bg-slate-800">
        <div
          id="course-progress-fill"
          class="h-full rounded-full bg-gradient-to-r from-violet-600 to-violet-400 transition-all duration-500"
          style="width: 0%"
        >
        </div>
      </div>
    </div>

    <!-- Modules -->
    <div class="space-y-6">
      {
        modules.map((module: Module, moduleIndex: number) => (
          <div class="overflow-hidden rounded-xl border border-slate-800">
            <div class="border-b border-slate-800 bg-slate-900/80 px-6 py-4">
              <div class="flex items-center justify-between gap-3">
                <h2 class="text-base font-semibold text-slate-200">
                  <span class="mr-2 text-violet-400">Module {moduleIndex}</span>
                  {module.title}
                </h2>
                {module.public && (
                  <span
                    class={`shrink-0 rounded-md px-2 py-0.5 text-xs font-medium ${
                      module.public === 'tous'
                        ? 'border border-emerald-500/20 bg-emerald-500/10 text-emerald-400'
                        : 'border border-sky-500/20 bg-sky-500/10 text-sky-400'
                    }`}
                  >
                    {module.public === 'tous' ? 'Tous' : 'Profils techniques'}
                  </span>
                )}
              </div>

              {module.objectifs && module.objectifs.length > 0 && (
                <ul class="mt-3 space-y-1">
                  {module.objectifs.map((obj: string) => (
                    <li class="flex items-start gap-2 text-sm text-slate-400">
                      <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-violet-400/60" />
                      {obj}
                    </li>
                  ))}
                </ul>
              )}

              {module.livrable && (
                <div class="mt-3 flex items-start gap-2 text-sm">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-amber-400/70"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    />
                  </svg>
                  <span class="text-slate-400">
                    <span class="font-medium text-slate-300">Livrable :</span>{' '}
                    {module.livrable}
                  </span>
                </div>
              )}

              {module.exercices && module.exercices.length > 0 && (
                <div class="mt-3">
                  <div class="mb-1 text-xs font-medium tracking-wider text-slate-500 uppercase">
                    Exercices
                  </div>
                  <ul class="space-y-1">
                    {module.exercices.map((ex: string) => (
                      <li class="flex items-start gap-2 text-sm text-slate-400">
                        <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-emerald-400/60" />
                        {ex}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
            <ul class="divide-y divide-slate-800/50">
              {module.lessons.map((lesson: Lesson, lessonIndex: number) => (
                <li>
                  <a
                    href={`${base}lessons/${course.id}/${lesson.slug}`}
                    data-lesson-item={lesson.slug}
                    class="group flex items-center gap-4 px-6 py-4 transition-colors hover:bg-slate-800/30"
                  >
                    <div class="lesson-number flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-slate-700 text-sm text-slate-500 transition-colors group-hover:border-violet-500/40 group-hover:text-violet-400">
                      {lessonIndex + 1}
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="text-sm font-medium text-slate-300 transition-colors group-hover:text-slate-100">
                        {lesson.title}
                      </div>
                    </div>
                    <svg
                      class="h-4 w-4 shrink-0 text-slate-600 transition-colors group-hover:text-slate-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <script is:inline define:vars={{ courseId: course.id, totalLessons }}>
    (function () {
      const progress = JSON.parse(
        localStorage.getItem(`progress_${courseId}`) || '[]',
      );
      const pct =
        totalLessons > 0
          ? Math.round((progress.length / totalLessons) * 100)
          : 0;

      const fill = document.getElementById('course-progress-fill');
      const text = document.getElementById('progress-text');
      if (fill) fill.style.width = pct + '%';
      if (text)
        text.textContent = progress.length + ' / ' + totalLessons + ' leçons';

      // Mark completed lessons
      progress.forEach(function (slug) {
        const item = document.querySelector(`[data-lesson-item="${slug}"]`);
        if (!item) return;
        const numEl = item.querySelector('.lesson-number');
        if (numEl) {
          numEl.innerHTML =
            '<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
          numEl.classList.add('border-emerald-500/30', 'bg-emerald-500/10');
          numEl.classList.remove('border-slate-700');
        }
      });
    })();
  </script>
</BaseLayout>
