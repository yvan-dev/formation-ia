---
import BaseLayout from '../layouts/BaseLayout.astro';
import LevelQuiz from '../components/LevelQuiz.tsx';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Evaluez votre niveau en IA">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <nav class="flex items-center gap-2 text-sm text-ink-500 mb-8" aria-label="Breadcrumb">
      <a href={base} class="hover:text-gold-400 transition-colors duration-200">Accueil</a>
      <svg class="w-4 h-4 text-ink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <span class="text-ink-200">Quiz de niveau</span>
    </nav>

    <div class="mb-10 text-center">
      <h1 class="font-display text-3xl lg:text-5xl font-bold text-ink-50 mb-4 leading-tight">
        Evaluez votre niveau en <span class="text-gold-500">IA</span>
      </h1>
      <p class="text-lg text-ink-300 max-w-xl mx-auto leading-relaxed">
        10 questions pour estimer vos connaissances en intelligence artificielle
        et vous orienter vers le bon point de depart.
      </p>
    </div>

    <LevelQuiz client:load basePath={base} />
  </div>
</BaseLayout>
