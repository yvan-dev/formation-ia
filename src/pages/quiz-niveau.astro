---
import BaseLayout from '../layouts/BaseLayout.astro';
import LevelQuiz from '../components/LevelQuiz.tsx';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Quiz de niveau">
  <section class="mx-auto max-w-2xl px-6 py-16">
    <div class="mb-10 text-center">
      <h1 class="text-navy-50 mb-4 text-3xl font-bold">
        Evaluez votre niveau en IA
      </h1>
      <p class="text-navy-400 text-lg">
        10 questions pour decouvrir votre niveau et obtenir des recommandations
        personnalisees.
      </p>
    </div>

    <LevelQuiz client:load basePath={base} />
  </section>
</BaseLayout>
