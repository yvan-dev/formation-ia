---
import BaseLayout from '../layouts/BaseLayout.astro';
import LevelQuiz from '../components/LevelQuiz.tsx';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Quiz de niveau">
  <section class="container-shell py-10 md:py-14">
    <div class="surface-card px-6 py-7 md:px-10 md:py-10">
      <p class="text-xs font-semibold tracking-[0.16em] text-[var(--text-faint)] uppercase">Diagnostic initial</p>
      <h1 class="section-title mt-3 text-3xl text-[var(--text-primary)] md:text-5xl">Évaluons notre maturité IA</h1>
      <p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--text-muted)] md:text-base">
        10 questions pour estimer notre niveau actuel et orienter la progression: fondamentaux, engineering de prompts, sécurité et agentique.
      </p>

      <div class="mt-6">
        <LevelQuiz client:load basePath={base} />
      </div>
    </div>
  </section>
</BaseLayout>

