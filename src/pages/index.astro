---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.astro';
import MaturityStepper from '../components/MaturityStepper.astro';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses');
const base = import.meta.env.BASE_URL;
const totalLessons = courses.reduce(
  (acc, c) => acc + c.data.modules.reduce((a, m) => a + m.lessons.length, 0),
  0,
);
---

<BaseLayout title="Accueil">
  <section class="container-shell relative overflow-hidden py-10 md:py-14">
    <div class="surface-card relative overflow-hidden px-6 py-10 md:px-10 md:py-14">
      <div class="grid-pattern"></div>

      <div class="relative grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div>
          <p class="reveal text-xs font-semibold tracking-[0.18em] text-[var(--text-faint)] uppercase">
            Accompagnement IA appliqué aux métiers tech
          </p>

          <h1 class="hero-text reveal reveal-2 mt-4 text-4xl leading-[1.02] font-semibold text-[var(--text-primary)] md:text-6xl">
            Transformons nos méthodes de travail
            <span class="brand-gradient-text">en prenant le tournant de l'IA</span>
          </h1>

          <p class="reveal reveal-3 mt-5 max-w-2xl text-base leading-relaxed text-[var(--text-muted)] md:text-lg">
            Ce parcours nous aide à adopter l'IA de manière progressive, responsable et concrète: pratiques de terrain, sécurité, automatisation et mise en production guidée.
          </p>

          <div class="reveal reveal-4 mt-7 flex flex-wrap items-center gap-3">
            <a href="#formations" class="btn-primary">
              Explorer les formations
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
            <a href={`${base}quiz-niveau`} class="btn-ghost">Passer le quiz de niveau</a>
          </div>
        </div>

        <div class="reveal reveal-3 space-y-3 rounded-[1.1rem] border border-[var(--border)] bg-[color-mix(in_srgb,var(--surface)_90%,transparent)] p-5">
          <div class="flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3">
            <span class="text-sm text-[var(--text-muted)]">Formations disponibles</span>
            <strong class="section-title text-2xl text-[var(--text-primary)]">{courses.length}</strong>
          </div>
          <div class="flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3">
            <span class="text-sm text-[var(--text-muted)]">Leçons opérationnelles</span>
            <strong class="section-title text-2xl text-[var(--text-primary)]">{totalLessons}</strong>
          </div>
          <div class="rounded-xl border border-[var(--border)] px-4 py-3">
            <p class="text-sm text-[var(--text-muted)]">Objectif partagé</p>
            <p class="mt-1 text-base font-semibold text-[var(--text-primary)]">Renforcer notre autonomie sur les workflows IA encadrés</p>
          </div>
          <div class="rounded-xl border border-[var(--border)] px-4 py-3">
            <p class="text-sm text-[var(--text-muted)]">Format</p>
            <p class="mt-1 text-base font-semibold text-[var(--text-primary)]">Ateliers pratiques, cas métier et capstone AGENT.md</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell pb-3 md:pb-6">
    <MaturityStepper basePath={base} courseSlug="ia-appliquee-metiers-tech" variant="home" />
  </section>

  <section class="container-shell py-5 md:py-8">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="surface-card px-5 py-5">
        <p class="text-xs font-semibold tracking-[0.13em] text-[var(--text-faint)] uppercase">01 Gouvernance</p>
        <h2 class="section-title mt-2 text-xl">Cadre d'usage robuste</h2>
        <p class="mt-2 text-sm text-[var(--text-muted)]">Nous alignons nos pratiques: sécurité, confidentialité, qualité de prompts et gestion des risques.</p>
      </article>
      <article class="surface-card px-5 py-5">
        <p class="text-xs font-semibold tracking-[0.13em] text-[var(--text-faint)] uppercase">02 Exécution</p>
        <h2 class="section-title mt-2 text-xl">Méthodes orientées delivery</h2>
        <p class="mt-2 text-sm text-[var(--text-muted)]">Plan-first, spec-driven development, instrumentation et points de validation humaine.</p>
      </article>
      <article class="surface-card px-5 py-5">
        <p class="text-xs font-semibold tracking-[0.13em] text-[var(--text-faint)] uppercase">03 Impact</p>
        <h2 class="section-title mt-2 text-xl">Livrables réutilisables</h2>
        <p class="mt-2 text-sm text-[var(--text-muted)]">Chaque personne repart avec un système de travail IA documenté et directement exploitable.</p>
      </article>
    </div>
  </section>

  <section id="formations" class="container-shell py-10 md:py-14">
    <div class="mb-7 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-xs font-semibold tracking-[0.16em] text-[var(--text-faint)] uppercase">Catalogue</p>
        <h2 class="section-title mt-2 text-3xl text-[var(--text-primary)] md:text-4xl">Toutes les formations</h2>
      </div>
      <p class="max-w-xl text-sm text-[var(--text-muted)] md:text-base">
        Choisissons un parcours selon nos rôles et notre maturité IA, des fondamentaux jusqu'à l'implémentation agentique guidée.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        courses.map((course, i) => (
          <div style={`animation-delay:${0.06 * i}s`}>
            <CourseCard
              slug={course.id}
              title={course.data.title}
              description={course.data.description}
              level={course.data.level}
              lessonCount={course.data.modules.reduce((a, m) => a + m.lessons.length, 0)}
            />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

