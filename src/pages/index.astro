---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.astro';
import MaturityStepper from '../components/MaturityStepper.astro';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses');
const base = import.meta.env.BASE_URL;
const primaryCourse = courses.find((course) => course.id === 'ia-appliquee-metiers-tech') ?? courses[0];

if (!primaryCourse) {
  throw new Error('Aucune formation disponible');
}

const releasedModules = primaryCourse.data.modules.filter((module, index) =>
  typeof module.released === 'boolean' ? module.released : index < 3,
);

const operationalModules = releasedModules.length;
const operationalLessons = releasedModules.reduce((acc, module) => acc + module.lessons.length, 0);
---

<BaseLayout title="Accueil">
  <section class="container-shell relative overflow-hidden py-10 md:py-14">
    <div class="surface-card relative overflow-hidden px-6 py-10 md:px-10 md:py-14">
      <div class="grid-pattern"></div>

      <div class="relative grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div>
          <p class="reveal text-xs font-semibold tracking-[0.18em] text-[var(--text-faint)] uppercase">
            Accompagnement IA appliqué aux métiers tech
          </p>

          <h1 class="hero-text reveal reveal-2 mt-4 text-4xl leading-[1.02] font-semibold text-[var(--text-primary)] md:text-6xl">
            Positionnons-nous avec un quiz
            <span class="brand-gradient-text">avant de lancer la formation</span>
          </h1>

          <p class="reveal reveal-3 mt-5 max-w-2xl text-base leading-relaxed text-[var(--text-muted)] md:text-lg">
            En 4 minutes, nous identifions notre niveau actuel et la prochaine étape utile pour progresser ensemble, sans détour théorique inutile.
          </p>

          <div class="reveal reveal-4 mt-7 flex flex-wrap items-center gap-3">
            <a href={`${base}courses/${primaryCourse.id}`} class="btn-ghost">Découvrir notre première formation</a>
            <a href={`${base}quiz-niveau`} class="btn-primary">
              Faire un quiz de placement
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="reveal reveal-3 space-y-3 rounded-[1.1rem] border border-[var(--border)] bg-[color-mix(in_srgb,var(--surface)_90%,transparent)] p-5">
          <div class="flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3">
            <span class="text-sm text-[var(--text-muted)]">Modules opérationnels aujourd'hui</span>
            <strong class="section-title text-2xl text-[var(--text-primary)]">{operationalModules}</strong>
          </div>
          <div class="flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface-strong)] px-4 py-3">
            <span class="text-sm text-[var(--text-muted)]">Leçons disponibles immédiatement</span>
            <strong class="section-title text-2xl text-[var(--text-primary)]">{operationalLessons}</strong>
          </div>
          <div class="rounded-xl border border-[var(--brand-300)] bg-[rgba(23,229,23,0.12)] px-4 py-3">
            <p class="text-sm font-semibold text-[var(--brand-700)]">
              Objectif immédiat: nous amener collectivement au niveau 3 (Agent guidé).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell pb-3 md:pb-6">
    <div class="mb-4 rounded-2xl border border-[var(--brand-300)] bg-[rgba(23,229,23,0.09)] px-5 py-4">
      <p class="text-xs font-semibold tracking-[0.14em] text-[var(--text-faint)] uppercase">Repère de progression</p>
      <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] md:text-base">
        Le quiz vous positionne rapidement. La grille ci-dessous sert à rendre le chemin de progression visible pour toute l'équipe.
      </p>
    </div>

    <MaturityStepper basePath={base} courseSlug={primaryCourse.id} variant="home" />
  </section>

  <section id="formations" class="container-shell py-10 md:py-14">
    <div class="mb-7 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-xs font-semibold tracking-[0.16em] text-[var(--text-faint)] uppercase">Formation</p>
        <h2 class="section-title mt-2 text-3xl text-[var(--text-primary)] md:text-4xl">Découvrir notre première formation</h2>
      </div>
      <p class="max-w-xl text-sm text-[var(--text-muted)] md:text-base">
        Un parcours concret pour passer d'usages ponctuels à un workflow développeur assisté par IA, étape par étape.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:max-w-[460px]">
      {
        primaryCourse && (
          <CourseCard
            slug={primaryCourse.id}
            title={primaryCourse.data.title}
            description={primaryCourse.data.description}
            level={primaryCourse.data.level}
            lessonCount={operationalLessons}
            moduleCount={operationalModules}
            ctaLabel="Découvrir notre première formation"
          />
        )
      }
    </div>
  </section>
</BaseLayout>