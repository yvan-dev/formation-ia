---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Plateforme de formation en ligne - Apprenez à votre rythme',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <title>{title} | Formation IA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <header
      class="border-navy-800/60 bg-navy-950/90 sticky top-0 z-50 border-b backdrop-blur-md"
    >
      <nav
        class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6"
      >
        <a href={base} class="group flex items-center gap-3">
          <img
            src={`${base}favicon.jpg`}
            alt="Formation IA"
            class="h-9 w-9 rounded-md shadow-lg"
          />
          <span class="text-navy-50 text-lg font-semibold tracking-tight"
            >Formation <span class="text-acton-600">IA</span></span
          >
        </a>
        <div class="flex items-center gap-6">
          <a
            href={base}
            class="text-navy-400 hover:text-acton-500 text-sm transition-colors duration-200"
            >Cours</a
          >
          <div id="search-container">
            <button
              id="search-trigger"
              class="border-navy-700/50 text-navy-400 hover:border-acton-600/30 hover:text-acton-500 flex items-center gap-2 rounded-lg border px-3 py-1.5 text-sm transition-all duration-200"
              aria-label="Rechercher"
            >
              <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <span class="hidden sm:inline">Rechercher</span>
              <kbd
                class="text-navy-500 bg-navy-800/50 border-navy-700/50 ml-2 hidden items-center gap-0.5 rounded border px-1.5 py-0.5 font-mono text-[10px] sm:inline-flex"
              >
                <span>&#8984;</span>K
              </kbd>
            </button>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-navy-800/40 mt-auto border-t">
      <div class="mx-auto max-w-7xl px-6 py-10">
        <div
          class="flex flex-col items-center justify-between gap-4 sm:flex-row"
        >
          <div class="flex items-center gap-2">
            <img
              src={`${base}favicon.jpg`}
              alt="Formation IA"
              class="h-6 w-6 rounded"
            />
            <span class="text-navy-500 text-sm">Formation IA</span>
          </div>
          <p class="text-navy-600 text-sm">
            &copy; {new Date().getFullYear()} Formation IA - GUNEWOU TAKAM Yvan. Tous
            droits réservés.
          </p>
        </div>
      </div>
    </footer>

    <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
    <script is:inline define:vars={{ base }}>
      window.addEventListener('DOMContentLoaded', () => {
        const trigger = document.getElementById('search-trigger');
        if (!trigger) return;

        let searchModal = null;
        let pagefindLoaded = false;

        function createModal() {
          const wrapper = document.createElement('div');
          wrapper.id = 'search-modal';
          wrapper.className =
            'fixed inset-0 z-[100] flex items-start justify-center pt-24 px-4';
          wrapper.style.animation = 'fadeIn 0.15s ease-out';
          wrapper.innerHTML = `
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="search-backdrop"></div>
            <div class="relative w-full max-w-2xl bg-navy-900 border border-navy-700/50 rounded-2xl shadow-2xl shadow-black/40 overflow-hidden" style="animation: fadeUp 0.2s ease-out">
              <div id="pagefind-search"></div>
            </div>
          `;
          document.body.appendChild(wrapper);
          wrapper
            .querySelector('#search-backdrop')
            ?.addEventListener('click', closeSearch);
          return wrapper;
        }

        function openSearch() {
          if (searchModal) {
            searchModal.style.display = '';
            const input = searchModal.querySelector('input');
            if (input) {
              input.focus();
              input.select();
            }
            document.addEventListener('keydown', handleEsc);
            return;
          }

          searchModal = createModal();
          document.addEventListener('keydown', handleEsc);

          if (pagefindLoaded) return;
          pagefindLoaded = true;

          const script = document.createElement('script');
          script.src = base + 'pagefind/pagefind-ui.js';
          script.onload = function () {
            new window.PagefindUI({
              element: '#pagefind-search',
              showSubResults: true,
              showImages: false,
            });
            const input = searchModal.querySelector('input');
            if (input) input.focus();
          };
          script.onerror = function () {
            pagefindLoaded = false;
            const el = searchModal.querySelector('#pagefind-search');
            if (el) {
              el.innerHTML =
                '<p style="padding:1.5rem;text-align:center;color:#9ca3af;">La recherche n\u2019est pas disponible. Lancez <code style="background:#1e293b;padding:2px 6px;border-radius:4px;">npm run build</code> pour indexer le contenu.</p>';
            }
          };
          document.head.appendChild(script);
        }

        function closeSearch() {
          if (searchModal) {
            searchModal.style.display = 'none';
          }
          document.removeEventListener('keydown', handleEsc);
        }

        function handleEsc(e) {
          if (e.key === 'Escape') closeSearch();
        }

        trigger.addEventListener('click', openSearch);

        // Cmd+K shortcut
        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            if (searchModal && searchModal.style.display !== 'none') {
              closeSearch();
            } else {
              openSearch();
            }
          }
        });
      });
    </script>
  </body>
</html>
